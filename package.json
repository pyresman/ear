{
  "name": "earbomb-cf",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "node scripts/build-config.js",
    "db:create": "wrangler d1 create earbomb-db",
    "db:init": "wrangler d1 execute earbomb-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute earbomb-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "wrangler": "^4.77.0"
  }
}
